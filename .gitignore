# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging and build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Environment and secrets
.env
.env.*
!.env.example

# Logs and runtime artifacts
*.log
*.pid

# Local databases / temp files
*.sqlite
*.sqlite3

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Data files
data/*
!data/.gitkeep
!data/bronze/.gitkeep
!data/silver/.gitkeep
!data/checkpoints/.gitkeep

# Spark
.spark_staging/
checkpoint*/

# Pentaho generated files
pentaho/*.ktr
pentaho/*.kjb

# But keep the generator and docs
!pentaho/generate_ktr.py
!pentaho/run_pentaho_batch.py
!pentaho/README.md
!pentaho/Dockerfile
# Pentaho generated files
pentaho/jobs/*.ktr
pentaho/jobs/*.kjb
!pentaho/jobs/silver_to_gold.ktr
!pentaho/jobs/run_pipeline.kjb

# Pentaho logs
pentaho/logs/
